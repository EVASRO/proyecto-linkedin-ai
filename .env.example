# Auth.js — genera uno nuevo: openssl rand -base64 32
AUTH_SECRET=

# URL de la app (desarrollo)
AUTH_URL=http://localhost:3000

# Usuario demo (credenciales por defecto: demo@nexusai.app / demo1234)
DEMO_USER_EMAIL=demo@nexusai.app
DEMO_USER_NAME=Usuario Demo
# Contraseña demo en texto plano (solo desarrollo)
DEMO_USER_PASSWORD=demo1234
# Hash bcrypt — usar comillas por los caracteres $
DEMO_USER_PASSWORD_HASH="$2b$10$F660F042aG68zY2JsGmdfebwJ4L5inZDDDN9jaxKP/rLyYjGqPzca"

# OAuth Google (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
